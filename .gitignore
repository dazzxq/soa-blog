.env
.env.*
!.env.example
vendor/
# composer.lock IS committed — apps lock deps for reproducible builds
.DS_Store
*.log
.idea/
.vscode/
node_modules/

# Local data
data/
mariadb_data/

# Pre-wipe DB dumps taken by scripts/deploy.sh before the destructive migration
backups/

# SSL certs
deploy/certs/*.pem
deploy/certs/*.key
!deploy/certs/.gitkeep

# Local override
docker-compose.override.yml
.codex-review/

# Python caches (report generator)
__pycache__/
*.pyc

# Báo cáo đồ án — GIỮ LOCAL, không commit lên GitHub công khai (tránh đạo văn)
report/
