{
  "name": "soa-blog/gateway",
  "description": "API Gateway for SOA Blog — routing, JWT auth, composition, rate limit, logging",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "guzzlehttp/guzzle": "^7.8",
    "firebase/php-jwt": "^7.0",
    "monolog/monolog": "^3.0",
    "ramsey/uuid": "^4.7",
    "ext-mbstring": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
