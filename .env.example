# MariaDB
# Each *_SVC_DB_PASS MUST be SHELL-SAFE + COMPOSE-SAFE (ISSUE-6): charset
# [A-Za-z0-9] ONLY, length 32, NO  $  `  "  '  space  #  =  {  }  — these break
# `set -a; . ./.env; set +a` sourcing in scripts/deploy.sh and Docker Compose
# `.env` interpolation. Write the value WITHOUT quotes. Generate each with:
#     tr -dc 'A-Za-z0-9' </dev/urandom | head -c32; echo
# (The placeholders below are NOT valid values — replace them in the live .env.)
DB_ROOT_PASSWORD=change-me-root
PROFILE_SVC_DB_PASS=change-me-profile
CONNECTION_SVC_DB_PASS=change-me-connection
FEED_SVC_DB_PASS=change-me-feed
SEARCH_SVC_DB_PASS=change-me-search
NOTIFICATION_SVC_DB_PASS=change-me-notification

# JWT (gateway only)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Rate limit
RATE_LIMIT_PER_MIN=120
