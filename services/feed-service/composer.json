{
  "name": "soa-blog/feed-service",
  "description": "Feed stub microservice for ProConnect",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ezyang/htmlpurifier": "^4.19",
    "monolog/monolog": "^3.0",
    "slim/psr7": "^1.6",
    "slim/slim": "^4.12"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    }
  }
}
